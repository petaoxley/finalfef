<h1>Dashboard</h1>

<div class="grid">
  <div class="card">
    <h3>Average Mood</h3>
    <p>{{avgMood}}</p>
  </div>
</div>

<h2>Entries</h2>

{{#each entries}}
  <div class="card">
    <p>Mood: {{mood}}</p>
    <p>Sleep: {{sleepHours}}</p>
    <p>Stress: {{stress}}</p>
    <p>Wellbeing Score: {{wellbeingScore}}</p>
  </div>
{{/each}}