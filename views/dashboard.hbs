<h1>Dashboard</h1>

<div class="grid">
  <div class="card">
    <h2>Average Mood</h2>
    <p>{{avgMood}}</p>
  </div>

  <div class="card">
    <h2>Total Entries</h2>
    <p>{{entries.length}}</p>
  </div>
</div>

<h2>Recent Entries</h2>
<ul>
  {{#each entries}}
    <li>Mood: {{this.mood}} | Sleep: {{this.sleepHours}}</li>
  {{/each}}
</ul>